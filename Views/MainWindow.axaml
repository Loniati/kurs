<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaApplication1.ViewModels"
        x:Class="AvaloniaApplication1.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Учет студентов" Height="400" Width="600">
    
    <StackPanel Margin="20" Spacing="10">
        <TextBox Text="{Binding CurrentName}" PlaceholderText="ФИО"/>
        <TextBox Text="{Binding CurrentGroup}" PlaceholderText="Группа"/>
        <TextBox Text="{Binding CurrentAdvisor}" PlaceholderText="Науч. рук."/>
        
        <Button Content="Добавить" Command="{Binding AddCommand}"/>
        <Button Content="Удалить" Command="{Binding DeleteCommand}"/>
        
        <ListBox ItemsSource="{Binding Students}" SelectedItem="{Binding SelectedStudent}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </StackPanel>
</Window>